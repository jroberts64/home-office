# Copy this file to `esp32/.env` (gitignored) and fill in real values.
# Used by esp32/tools/provision.py to provision the genesis_totp device over
# serial. Any value left blank/removed here is prompted for interactively.
#
# This .env is SEPARATE from the repo-root .env (which holds AWS_PROFILE for
# deploys). Keep the Wi-Fi password and TOTP secret here, in esp32/ only.

# 2.4 GHz network only — the ESP32-S3 has no 5 GHz radio.
WIFI_SSID=
WIFI_PASSWORD=

# The base32 shared secret. This MUST match the home-office SSM config's
# totp_secret (what the /unlock Lambda validates against), so the code the
# gadget shows is the code the site accepts. Read the live value with:
#   aws ssm get-parameter --name /home-office/config --with-decryption \
#     --query Parameter.Value --output text | jq -r .totp_secret
TOTP_SECRET=
