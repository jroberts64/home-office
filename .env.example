# Copy this to .env (which is gitignored) for local deploys and parameter edits.
# Sourced by deploy/*.sh and loaded by the Python helpers in docs/.
# In CI (GitHub Actions) there is no .env; the OIDC-assumed role supplies creds.

# AWS profile to use locally. Refresh it first with:
#   aws sso login --sso-session personal-sso
AWS_PROFILE=personal-sso

# Region (optional; scripts default to us-east-1 if unset).
AWS_REGION=us-east-1
